<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/aboutMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- FAKE STATUS BAR BACKGROUND -->
    <View
        android:id="@+id/statusBarBackgroundAbout"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#0F3D3E" />

    <!-- TOOLBAR -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAbout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FA7D68"
        android:minHeight="56dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#EEF6F7"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- AUTHOR / APP PHOTO -->
            <ImageView
                android:id="@+id/imgAuthor"
                android:src="@drawable/my_photo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="12dp"
                android:scaleType="centerCrop"
                android:contentDescription="Author Photo" />

            <!-- APP TITLE -->
            <TextView
                android:text="⛽ Petrol Cost Calculator"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0F3D3E"
                android:textAlignment="center"
                android:fontFamily="sans-serif-medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <TextView
                android:text="Smart petrol cost calculator with BUDI MADANI rebate estimation."
                android:textSize="14sp"
                android:textColor="#4B5563"
                android:textAlignment="center"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="3dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp" />

            <!-- ABOUT APP CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/about_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:text="📌 ABOUT THIS APP"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:text="This application helps users estimate petrol cost based on petrol price per liter, fuel usage, petrol type, and BUDI MADANI eligibility."
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- AUTHOR CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/about_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:text="👤 AUTHOR INFORMATION"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp" />

                <TextView
                    android:text="👤 Name"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="NUR HASANATUN NASUHA BINTI MD AZLEE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:text="🆔 Matric Number"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="2025119111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:text="📘 Course"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="ICT602 - Mobile Technology"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:text="🎓 Lecturer"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:fontFamily="sans-serif"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="MADAM IDAYATI BINTI MAZLAN"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- GITHUB CARD / BUTTON -->
            <TextView
                android:id="@+id/tvGithub"
                android:text="🔗 Open GitHub Repository"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:fontFamily="sans-serif-medium"
                android:background="#E65100"
                android:padding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp" />

            <TextView
                android:text="© 2025 Nur Hasanatun Nasuha. All rights reserved."
                android:textSize="12sp"
                android:textColor="#888888"
                android:textAlignment="center"
                android:fontFamily="sans-serif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationAbout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#0F3D3E"
        app:itemTextColor="#0F3D3E"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>